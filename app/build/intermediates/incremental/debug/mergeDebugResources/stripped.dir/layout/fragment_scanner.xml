<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <android.support.v7.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1565C0"
        android:titleTextColor="@android:color/white"
        android:minHeight="?attr/actionBarSize" />

    <!-- Panel de feedback: verde OK / rojo duplicado -->
    <LinearLayout
        android:id="@+id/panelFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1565C0"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:id="@+id/txtFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Listo para escanear"
            android:textColor="@android:color/white"
            android:textSize="13sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/txtCodeDisplay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:gravity="center"
            android:paddingTop="4dp"
            android:singleLine="true"
            android:ellipsize="middle" />
    </LinearLayout>

    <!-- Estadísticas: escaneados + canjeados -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtEscaneados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 escaneados"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#0D47A1"
            android:background="#BBDEFB"
            android:padding="10dp"
            android:gravity="center" />

        <TextView
            android:id="@+id/txtCanjeados"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 canjeados"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:background="#C8E6C9"
            android:padding="10dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Vista de cámara (oculta por defecto) -->
    <com.journeyapps.barcodescanner.DecoratedBarcodeView
        android:id="@+id/barcodeScanner"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:visibility="gone" />

    <!-- Botón cerrar cámara (oculto por defecto) -->
    <Button
        android:id="@+id/btnCloseCamera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cerrar cámara"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:background="#B71C1C"
        android:visibility="gone"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Fila de input (escáner de hardware / teclado) -->
    <LinearLayout
        android:id="@+id/layoutInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:gravity="center_vertical">

        <android.support.design.widget.TextInputLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Código de entrada">

            <android.support.design.widget.TextInputEditText
                android:id="@+id/editCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:textSize="16sp" />
        </android.support.design.widget.TextInputLayout>

        <Button
            android:id="@+id/btnEnter"
            android:layout_width="56dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="OK"
            android:textStyle="bold"
            android:background="#1565C0"
            android:textColor="@android:color/white" />
    </LinearLayout>

    <!-- Fila de botones: cámara + limpiar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp">

        <Button
            android:id="@+id/btnCamera"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="Usar cámara"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="#2E7D32"
            android:layout_marginEnd="6dp" />

        <Button
            android:id="@+id/btnClear"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:text="Limpiar todo"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="#B71C1C"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Separador + cabecera lista -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Registro de boletos"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="#424242"
        android:background="#F5F5F5"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp" />

    <!-- Lista de códigos (más reciente arriba) -->
    <ListView
        android:id="@+id/listScannedCodes"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="#E0E0E0"
        android:dividerHeight="1dp" />

</LinearLayout>
